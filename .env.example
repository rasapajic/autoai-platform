# ============================================================
# AutoAI Platform - Environment Variables
# Kopiraj kao .env i popuni vrednosti
# ============================================================

# ─── Baza podataka ───────────────────────────────────────────
POSTGRES_PASSWORD=secret123
DATABASE_URL=postgresql://admin:secret123@localhost:5432/autoai

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Elasticsearch ───────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── AI API ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── Security ────────────────────────────────────────────────
SECRET_KEY=promeni_ovo_na_random_string_od_32_karaktera
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── App ─────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ─── Email (za alertove) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tvoj@gmail.com
SMTP_PASSWORD=app_password_ovde

# ─── Proxy (za scraping anti-bot zaštitu) ────────────────────
# PROXY_LIST=http://user:pass@proxy1.com:8080,http://user:pass@proxy2.com:8080
